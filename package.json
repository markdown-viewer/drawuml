{
  "name": "@markdown-viewer/draw-uml",
  "version": "1.4.1",
  "description": "Convert PlantUML text diagrams into DrawIO XML — supports class, sequence, activity, state, deployment and more",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "check": "fibjs --check -p ../tsconfig.json"
  },
  "files": [
    "src",
    "README.md"
  ],
  "keywords": [
    "plantuml",
    "drawio",
    "uml",
    "diagram",
    "svg",
    "mxgraph",
    "class-diagram",
    "sequence-diagram",
    "activity-diagram",
    "state-diagram",
    "fibjs",
    "elk",
    "graphviz"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nicedoc/draw-uml"
  },
  "homepage": "https://github.com/nicedoc/draw-uml#readme",
  "bugs": {
    "url": "https://github.com/nicedoc/draw-uml/issues"
  },
  "license": "GPL-3.0-only",
  "engines": {
    "fibjs": ">=0.38.0"
  },
  "dependencies": {
    "@markdown-viewer/text-measure": "^1.1.1",
    "@viz-js/viz": "^3.24.0",
    "elkjs": "^0.11.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
